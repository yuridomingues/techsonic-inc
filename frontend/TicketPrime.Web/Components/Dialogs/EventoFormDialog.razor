@using TicketPrime.Web.Models
@using TicketPrime.Web.Services
@using MudBlazor
@inject IApiService Api
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">Novo evento</MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form" Model="_model">
            <MudTextField @bind-Value="_model.Nome" Label="Nome do evento" Required="true" Variant="Variant.Outlined" Class="mb-3" />
            <MudSelect @bind-Value="_model.TipoEvento" Label="Tipo de evento" Variant="Variant.Outlined" Class="mb-3" Required="true">
                <MudSelectItem Value="@("show")">Show</MudSelectItem>
                <MudSelectItem Value="@("teatro")">Teatro</MudSelectItem>
                <MudSelectItem Value="@("estadio")">Estádio</MudSelectItem>
                <MudSelectItem Value="@("outro")">Outro</MudSelectItem>
            </MudSelect>
            <MudNumericField T="int" @bind-Value="_model.CapacidadeTotal" Label="Capacidade total" Min="1" Variant="Variant.Outlined" Class="mb-3" />
            <MudDatePicker @bind-Date="_data" Label="Data do evento" Variant="Variant.Outlined" Class="mb-3" Validation="@((DateTime? date) => ValidateDate(date))" />
            <MudNumericField T="decimal" @bind-Value="_model.PrecoPadrao" Label="Preço padrão (R$)" Format="N2" Culture="@System.Globalization.CultureInfo.GetCultureInfo("pt-BR")" Variant="Variant.Outlined" Class="mb-3" Min="@(0.01m)" />
            <MudTextField @bind-Value="_model.Descricao" Label="Descrição" Lines="3" Variant="Variant.Outlined" Class="mb-3" />
            <MudTextField @bind-Value="_model.LocalNome" Label="Local (nome)" Variant="Variant.Outlined" Class="mb-3" />
            <MudTextField @bind-Value="_model.LocalCidade" Label="Cidade" Variant="Variant.Outlined" Class="mb-3" />
            <MudTextField @bind-Value="_model.BannerUrl" Label="URL do banner (imagem)" Variant="Variant.Outlined" Class="mb-3" />
            <MudTextField @bind-Value="_model.GaleriaTexto" Label="Galeria (texto)" Lines="2" Variant="Variant.Outlined" Class="mb-3" />
            <MudNumericField T="decimal?" @bind-Value="_model.TaxaFixa" Label="Taxa fixa (R$)" Format="N2" Culture="@System.Globalization.CultureInfo.GetCultureInfo("pt-BR")" Variant="Variant.Outlined" Class="mb-3" />
            <MudCheckBox T="bool" @bind-Checked="_model.GerarSetoresAutomaticos" Label="Gerar setores e assentos padrão (Premium, Vip, Regular)" Class="mb-3" />
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancelar">Cancelar</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" Class="tp-action" Disabled="_saving" OnClick="SalvarAsync">Salvar</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    private MudForm? _form;
    private readonly EventoFormModel _model = new();
    private DateTime? _data = DateTime.Today.AddDays(1);
    private bool _saving;

    protected override void OnInitialized()
    {
        _data ??= DateTime.Today.AddDays(1);
    }

    private void Cancelar() => MudDialog.Cancel();

    private string? ValidateDate(DateTime? date)
    {
        if (date is null)
            return "Informe a data do evento.";
        if (date.Value.Date <= DateTime.Today)
            return "A data do evento deve ser futura.";
        return null;
    }

    private async Task SalvarAsync()
    {
        await (_form?.ValidateAsync() ?? Task.CompletedTask);
        if (_form is not null && !_form.IsValid)
            return;

        if (_data is null)
        {
            Snackbar.Add("Informe a data do evento.", Severity.Warning);
            return;
        }

        _saving = true;
        try
        {
            var dto = new EventoCreateDto(
                _model.Nome.Trim(),
                _model.CapacidadeTotal,
                _data.Value.Date,
                _model.PrecoPadrao,
                _model.TipoEvento,
                _model.Descricao,
                _model.LocalNome,
                _model.LocalCidade,
                _model.BannerUrl,
                _model.GaleriaTexto,
                _model.TaxaFixa,
                Status: "ativo");

            var result = await Api.PostEventoAsync(dto);
            if (result.Success)
            {
                var eventoId = result.Data!.Id;
                if (_model.GerarSetoresAutomaticos)
                {
                    var setoresResult = await Api.GerarSetoresAsync(eventoId);
                    if (setoresResult.Success)
                        Snackbar.Add("Setores gerados automaticamente.", Severity.Success);
                    else
                        Snackbar.Add("Evento criado, mas falha ao gerar setores.", Severity.Warning);
                }
                Snackbar.Add("Evento cadastrado com sucesso.", Severity.Success);
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
                Snackbar.Add(result.ErrorMessage ?? "Falha ao cadastrar evento.", Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    private sealed class EventoFormModel
    {
        public string Nome { get; set; } = string.Empty;
        public string TipoEvento { get; set; } = "show";
        public int CapacidadeTotal { get; set; } = 100;
        public decimal PrecoPadrao { get; set; } = 0;
        public string Descricao { get; set; } = string.Empty;
        public string LocalNome { get; set; } = string.Empty;
        public string LocalCidade { get; set; } = string.Empty;
        public string BannerUrl { get; set; } = string.Empty;
        public string GaleriaTexto { get; set; } = string.Empty;
        public decimal? TaxaFixa { get; set; }
        public bool GerarSetoresAutomaticos { get; set; } = true;
    }
}
