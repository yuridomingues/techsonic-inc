@using TicketPrime.Web.Models
@using TicketPrime.Web.Services
@inject IApiService Api
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">Finalizar pagamento</MudText>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3">
            <MudPaper Class="pa-4 tp-surface" Elevation="0">
                <MudText Typo="Typo.subtitle2">@Reserva.EventoNome</MudText>
                <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">
                    Status atual: @Reserva.Status
                </MudText>
                @if (!string.IsNullOrWhiteSpace(Reserva.AssentosResumo))
                {
                    <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">
                        Assentos: @Reserva.AssentosResumo
                    </MudText>
                }
                <MudText Typo="Typo.body1" Class="mt-3">
                    Valor final: @Reserva.ValorFinalPago.ToString("C", System.Globalization.CultureInfo.GetCultureInfo("pt-BR"))
                </MudText>
            </MudPaper>

            <MudForm @ref="_form">
                <MudSelect T="string" @bind-Value="_metodoPagamento" Label="Método de pagamento" Variant="Variant.Outlined" Class="mb-3">
                    <MudSelectItem Value="@("pix")">Pix</MudSelectItem>
                    <MudSelectItem Value="@("cartao_credito")">Cartão de crédito</MudSelectItem>
                    <MudSelectItem Value="@("cartao_debito")">Cartão de débito</MudSelectItem>
                </MudSelect>

                @if (_metodoPagamento == "cartao_credito")
                {
                    <MudNumericField T="int?"
                                     @bind-Value="_parcelas"
                                     Label="Parcelas"
                                     Variant="Variant.Outlined"
                                     Min="1"
                                     Max="12"
                                     Validation="@((int? valor) => ValidarParcelas(valor))" />
                }
            </MudForm>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancelar">Cancelar</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" Class="tp-action" Disabled="_saving" OnClick="PagarAsync">
            Processar pagamento
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public ReservaDto Reserva { get; set; } = default!;

    private MudForm? _form;
    private string _metodoPagamento = "pix";
    private int? _parcelas = 1;
    private bool _saving;

    private void Cancelar() => MudDialog.Cancel();

    private IEnumerable<string> ValidarParcelas(int? valor)
    {
        if (_metodoPagamento != "cartao_credito")
            return Enumerable.Empty<string>();

        if (valor is null || valor < 1 || valor > 12)
            return ["Parcelamento deve ficar entre 1 e 12."];

        return Enumerable.Empty<string>();
    }

    private async Task PagarAsync()
    {
        await (_form?.ValidateAsync() ?? Task.CompletedTask);
        if (_form is not null && !_form.IsValid)
            return;

        _saving = true;
        try
        {
            var pagamentoResult = await Api.SimulatePagamentoAsync(
                Reserva.Id,
                new PagamentoCreateDto(_metodoPagamento, _metodoPagamento == "cartao_credito" ? _parcelas : null));

            if (!pagamentoResult.Success || pagamentoResult.Data is null)
            {
                Snackbar.Add(pagamentoResult.ErrorMessage ?? "Não foi possível processar o pagamento.", Severity.Error);
                return;
            }

            var statusPagamento = pagamentoResult.Data.Status;
            if (string.Equals(statusPagamento, "aprovado", StringComparison.OrdinalIgnoreCase))
                Snackbar.Add("Pagamento aprovado com sucesso.", Severity.Success);
            else
                Snackbar.Add($"Pagamento retornou status {statusPagamento}. Você pode tentar novamente.", Severity.Warning);

            MudDialog.Close(DialogResult.Ok(true));
        }
        finally
        {
            _saving = false;
        }
    }
}