@page "/"

<PageTitle>TicketPrime — Dashboard</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true" Class="mb-1">Dashboard</MudText>
<MudText Typo="Typo.body1" Class="mb-6" Style="color: var(--mud-palette-text-secondary);">
    Visão geral do seu ecossistema de vendas (dados de exemplo até a API de métricas estar disponível).
</MudText>

<MudGrid Spacing="4">
    <MudItem xs="12" sm="6" md="3">
        <MudCard Class="tp-card" Elevation="8">
            <MudCardContent>
                <MudText Typo="Typo.overline" Style="color: var(--mud-palette-text-secondary);">Ingressos vendidos (24h)</MudText>
                <MudText Typo="Typo.h4" Style="color: var(--mud-palette-primary);">1.284</MudText>
                <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-secondary);">+12% vs. ontem</MudText>
            </MudCardContent>
        </MudCard>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudCard Class="tp-card" Elevation="8">
            <MudCardContent>
                <MudText Typo="Typo.overline" Style="color: var(--mud-palette-text-secondary);">Receita líquida</MudText>
                <MudText Typo="Typo.h4" Style="color: var(--mud-palette-secondary);">R$ 48.920</MudText>
                <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-secondary);">Meta semanal: 62%</MudText>
            </MudCardContent>
        </MudCard>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudCard Class="tp-card" Elevation="8">
            <MudCardContent>
                <MudText Typo="Typo.overline" Style="color: var(--mud-palette-text-secondary);">Eventos ativos</MudText>
                <MudText Typo="Typo.h4">14</MudText>
                <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-secondary);">3 em pré-venda</MudText>
            </MudCardContent>
        </MudCard>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudCard Class="tp-card" Elevation="8">
            <MudCardContent>
                <MudText Typo="Typo.overline" Style="color: var(--mud-palette-text-secondary);">Taxa de conversão</MudText>
                <MudText Typo="Typo.h4">3,8%</MudText>
                <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-secondary);">Checkout otimizado</MudText>
            </MudCardContent>
        </MudCard>
    </MudItem>

    <MudItem xs="12" lg="7">
        <MudPaper Class="pa-6 tp-card" Elevation="6">
            <MudText Typo="Typo.h6" GutterBottom="true">Atividade recente</MudText>
            <MudTimeline TimelineOrientation="TimelineOrientation.Vertical" TimelinePosition="TimelinePosition.Start">
                <MudTimelineItem Color="Color.Primary" Size="Size.Small">
                    <MudText Typo="Typo.subtitle2">Novo lote liberado — Show Aurora</MudText>
                    <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-secondary);">há 12 minutos</MudText>
                </MudTimelineItem>
                <MudTimelineItem Color="Color.Secondary" Size="Size.Small">
                    <MudText Typo="Typo.subtitle2">Cupom PRIME10 aplicado 214 vezes</MudText>
                    <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-secondary);">há 1 hora</MudText>
                </MudTimelineItem>
                <MudTimelineItem Color="Color.Default" Size="Size.Small">
                    <MudText Typo="Typo.subtitle2">Sincronização com gateway concluída</MudText>
                    <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-secondary);">há 3 horas</MudText>
                </MudTimelineItem>
            </MudTimeline>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" lg="5">
        <MudPaper Class="pa-6 tp-card" Elevation="6">
            <MudText Typo="Typo.h6" GutterBottom="true">Próximos passos</MudText>
            <MudList T="string" Dense="true">
                <MudListItem Icon="@Icons.Material.Filled.Bolt" IconColor="Color.Primary">
                    Conectar métricas reais da API
                </MudListItem>
                <MudListItem Icon="@Icons.Material.Filled.VerifiedUser" IconColor="Color.Secondary">
                    Autenticação e perfis de operador
                </MudListItem>
                <MudListItem Icon="@Icons.Material.Filled.Analytics" IconColor="Color.Primary">
                    Relatórios exportáveis (CSV / PDF)
                </MudListItem>
            </MudList>
        </MudPaper>
    </MudItem>
</MudGrid>
