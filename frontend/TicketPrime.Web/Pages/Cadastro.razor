@page "/cadastro"
@using MudBlazor

<MudContainer MaxWidth="MaxWidth.Small" Class="d-flex justify-center align-center" Style="min-height: 100vh;">
    <MudStack Spacing="6" Style="width: 100%;">

        <MudStack AlignItems="AlignItems.Center" Spacing="1">
            <MudText Typo="Typo.h4" Align="Align.Center" Style="font-weight: 700;">Cadastre-se</MudText>
        </MudStack>

        <MudPaper Class="pa-3 pa-sm-4 tp-form" Elevation="1" MaxWidth="MaxWidth.Medium">
    <MudForm @ref="_form" Model="_model">
        <MudTextField @bind-Value="_model.Nome"
                      Label="Nome completo"
                      Variant="Variant.Outlined"
                      Required="true"
                      Class="mb-4" />

        <MudTextField @bind-Value="_model.Cpf"
                      Label="CPF"
                      Mask="@(new PatternMask("000.000.000-00"))"
                      Variant="Variant.Outlined"
                      Required="true"
                      Class="mb-4" />

        <MudTextField @bind-Value="_model.Email"
                      Label="E-mail"
                      Variant="Variant.Outlined"
                      Required="true"
                      InputType="InputType.Email"
                      Class="mb-6" />

        <MudTextField @bind-Value="_model.Senha"
                      Label="Senha"
                      Variant="Variant.Outlined"
                      Required="true"
                      InputType="@(mostrarSenha ? InputType.Text : InputType.Password)"
                      Adornment="Adornment.End"
                      AdornmentIcon="@(mostrarSenha ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                      OnAdornmentClick="() => mostrarSenha = !mostrarSenha"
                      Class="mb-4" />

        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   Class="tp-action"
                   Size="Size.Large"
                   FullWidth="true"
                   Disabled="_saving"
                   OnClick="SalvarAsync">
            Cadastrar
        </MudButton>
    </MudForm>
</MudPaper>


    </MudStack>
</MudContainer>

@code {
    private MudForm _form = default!;
    private bool mostrarSenha = false;
    private bool _saving = false;

    private CadastroModel _model = new();

    private class CadastroModel
    {
        public string Nome { get; set; } = string.Empty;
        public string Cpf { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public string Senha { get; set; } = string.Empty;
    }

    private async Task SalvarAsync()
    {
        await _form.Validate();

        if (!_form.IsValid)
            return;

        _saving = true;

        // TODO: lógica de cadastro

        _saving = false;
    }
}